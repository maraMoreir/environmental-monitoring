# Copy to docker/.env (docker compose auto-loads it — this file is only a
# template and is never read directly). Required for the default Compose
# demo, which publishes real air-quality data via OpenWeatherMap instead of
# the synthetic simulator.
#
# 1. Sign up (free, no card) at https://openweathermap.org/api/air-pollution
# 2. Paste your API key below.
# 3. Set the coordinates for whatever city you want readings for.

ENVMON_OPENWEATHER_API_KEY=
ENVMON_OPENWEATHER_LATITUDE=-23.55
ENVMON_OPENWEATHER_LONGITUDE=-46.63
