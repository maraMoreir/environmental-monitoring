# Copy to .env and edit as needed. Nothing here needs to be a real secret —
# AWS credentials are read from the standard AWS credential chain (env vars,
# ~/.aws/credentials, or an IAM role), never from this file.

ENVMON_MQTT_BROKER_HOST=localhost
ENVMON_MQTT_BROKER_PORT=1883
ENVMON_MQTT_TOPIC=sensors/readings
ENVMON_MQTT_USE_TLS=false
ENVMON_MQTT_CA_CERT_PATH=

ENVMON_AWS_IOT_ENABLED=false
ENVMON_AWS_IOT_TOPIC=sensors/readings
ENVMON_AWS_REGION=us-east-1
ENVMON_AWS_IOT_ENDPOINT=

ENVMON_DATABASE_PATH=data/readings.db
ENVMON_DASHBOARD_PORT=8050
ENVMON_DEBUG=false

ENVMON_SENSOR_ID=sensor-001
ENVMON_SIMULATION_INTERVAL_SECONDS=5.0
